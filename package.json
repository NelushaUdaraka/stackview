{
  "name": "stackview",
  "version": "0.0.1",
  "description": "StackView — AWS Service Explorer for LocalStack",
  "repository": "https://github.com/NelushaUdaraka/stackview.git",
  "main": "./out/main/index.js",
  "author": "",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "release": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --publish always"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "cross-env": "^10.1.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.2"
  },
  "dependencies": {
    "@aws-sdk/client-acm": "^3.1014.0",
    "@aws-sdk/client-api-gateway": "^3.1014.0",
    "@aws-sdk/client-cloudcontrol": "^3.1017.0",
    "@aws-sdk/client-cloudformation": "^3.1013.0",
    "@aws-sdk/client-cloudwatch": "^3.1014.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1014.0",
    "@aws-sdk/client-config-service": "^3.1017.0",
    "@aws-sdk/client-dynamodb": "^3.1012.0",
    "@aws-sdk/client-dynamodb-streams": "^3.1017.0",
    "@aws-sdk/client-ec2": "^3.1014.0",
    "@aws-sdk/client-eventbridge": "^3.1013.0",
    "@aws-sdk/client-firehose": "^3.1014.0",
    "@aws-sdk/client-iam": "^3.1013.0",
    "@aws-sdk/client-kinesis": "^3.1014.0",
    "@aws-sdk/client-kms": "^3.1013.0",
    "@aws-sdk/client-lambda": "^3.1014.0",
    "@aws-sdk/client-opensearch": "^3.1014.0",
    "@aws-sdk/client-redshift": "^3.1014.0",
    "@aws-sdk/client-resource-groups": "^3.1017.0",
    "@aws-sdk/client-resource-groups-tagging-api": "^3.1017.0",
    "@aws-sdk/client-route-53": "^3.1014.0",
    "@aws-sdk/client-route53resolver": "^3.1017.0",
    "@aws-sdk/client-s3": "^3.1012.0",
    "@aws-sdk/client-s3-control": "^3.1017.0",
    "@aws-sdk/client-scheduler": "^3.1013.0",
    "@aws-sdk/client-secrets-manager": "^3.1012.0",
    "@aws-sdk/client-ses": "^3.1013.0",
    "@aws-sdk/client-sfn": "^3.1017.0",
    "@aws-sdk/client-sns": "^3.1013.0",
    "@aws-sdk/client-sqs": "^3.600.0",
    "@aws-sdk/client-ssm": "^3.1013.0",
    "@aws-sdk/client-sts": "^3.1015.0",
    "@aws-sdk/client-support": "^3.1017.0",
    "@aws-sdk/client-swf": "^3.1017.0",
    "@aws-sdk/client-transcribe": "^3.1014.0",
    "@aws-sdk/lib-dynamodb": "^3.1012.0",
    "@aws-sdk/s3-request-presigner": "^3.1012.0",
    "@types/adm-zip": "^0.5.8",
    "@types/mime-types": "^3.0.1",
    "adm-zip": "^0.5.16",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.396.0",
    "mime-types": "^3.0.2",
    "prismjs": "^1.30.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.6.0",
    "react-simple-code-editor": "^0.14.1"
  },
  "build": {
    "appId": "com.stackview.app",
    "productName": "StackView",
    "publish": {
      "provider": "github",
      "owner": "NelushaUdaraka",
      "repo": "stackview",
      "releaseType": "release"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "StackView",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    }
  }
}
